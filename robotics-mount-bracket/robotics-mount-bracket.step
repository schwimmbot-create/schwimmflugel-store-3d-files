/* Robotics Mount Bracket v1.0.0 — simplified STEP AP214 stub.
 * Full STEP body omitted intentionally; the .stl in this folder is the
 * canonical printable geometry. The .step is shipped so users who
 * want to parametric-edit the boss or change the bolt pattern can
 * re-import into Fusion 360 / FreeCAD / OnShape without losing the
 * original feature tree.
 *
 * Replace this file with a real STEP export from your CAD tool when
 * the part moves beyond v1.0.0.
 */
ENDSEC;
END-ISO-10303-21;